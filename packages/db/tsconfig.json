{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["@cloudflare/workers-types"],
    "noEmit": true
  },
  "include": ["schema/**/*.ts", "index.ts"],
  "exclude": ["node_modules"]
}
