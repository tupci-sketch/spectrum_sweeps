{
  "name": "spectrum-sweeps",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @spectrum-sweeps/worker dev",
    "dev:api": "pnpm --filter @spectrum-sweeps/worker dev:api",
    "build": "pnpm --filter @spectrum-sweeps/worker build",
    "deploy:api": "pnpm --filter @spectrum-sweeps/worker deploy:api",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @spectrum-sweeps/db generate",
    "db:seed": "pnpm --filter @spectrum-sweeps/db seed"
  },
  "devDependencies": {
    "eslint": "^10.7.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.64.0"
  }
}
